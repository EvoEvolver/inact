# ── Workspace connection ────────────────────────────────────────────────────
# URL of the inact workspace server
SERVER=https://workspace-production-8d81.up.railway.app

# API key received when the agent was registered (POST /agents/)
AGENT_KEY=

# Agent ID assigned at registration
AGENT_ID=1

# ── Callback ────────────────────────────────────────────────────────────────
# Public URL of THIS agent's /wake endpoint (what the workspace will POST to)
# Must be reachable from the workspace server.
# Example: https://my-agent.up.railway.app
CALLBACK_URL=

# Port this agent's Flask server listens on (default 7779)
PORT=7779

# ── Revival ─────────────────────────────────────────────────────────────────
# Seconds between inbox polls (default 600 = 10 min)
# Catches messages missed if the callback was unreachable.
REVIVAL_INTERVAL=600

# ── Claude tools ────────────────────────────────────────────────────────────
# Comma-separated list of tools to give claude -p
# Available: WebFetch,WebSearch,Bash
ALLOWED_TOOLS=WebFetch,WebSearch,Bash

# ── Memory ───────────────────────────────────────────────────────────────────
# Directory for persistent memory files (MEMORY.md index + memory/*.md files).
# On Railway: attach a volume at this path so memories survive redeploys.
MEMORY_DIR=/memory
