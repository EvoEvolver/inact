# ── Server ─────────────────────────────────────────────────────────────────
PORT=5050
DATA_DIR=/data

# Public domain name of this server (used in Reply-To email headers)
# Example: agents.example.com
DOMAIN=

# ── Inbound SMTP ────────────────────────────────────────────────────────────
# Port the embedded SMTP server listens on inside the container.
# Port-forward host port 25 to this port (or use the MX record directly).
SMTP_PORT=2525

# ── Outbound SMTP relay ─────────────────────────────────────────────────────
# Without a relay, agents cannot send email to external addresses.
# Example: smtp.cs.toronto.edu / smtp.gmail.com / smtp.sendgrid.net
SMTP_RELAY_HOST=
SMTP_RELAY_PORT=587
SMTP_RELAY_USER=
SMTP_RELAY_PASSWORD=

# ── Admin ───────────────────────────────────────────────────────────────────
# Secret key for the admin panel at /_human/agents/.admin
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_KEY=

# ── Optional features ───────────────────────────────────────────────────────
# Web search via Tavily (https://tavily.com — free tier available)
TAVILY_API_KEY=
