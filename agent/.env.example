# ── Workspace connection ────────────────────────────────────────────────────
# URL of the inact workspace server
WORKSPACE_HOST=

# API key received when the agent was registered (POST /agents/)
AGENT_KEY=

# ── Callback ────────────────────────────────────────────────────────────────
# Public URL of THIS agent's /wake endpoint (what the workspace will POST to)
# Must be reachable from the workspace server.
# Example: https://my-agent.up.railway.app
CALLBACK_URL=

# Port this agent's Flask server listens on (default 7779)
PORT=7779

# ── Revival ─────────────────────────────────────────────────────────────────
# Seconds between inbox polls (default 600 = 10 min)
# Catches messages missed if the callback was unreachable.
REVIVAL_INTERVAL=600


# ── Memory ───────────────────────────────────────────────────────────────────
# Directory for persistent memory files (MEMORY.md index + memory/*.md files).
# On Railway: attach a volume at this path so memories survive redeploys.
MEMORY_DIR=/memory

# Internal URL of this agent's own server (used by the agent to call /memory
# endpoints). Override if the server is not on localhost or uses a non-default port.
AGENT_SERVER_URL=http://localhost:7779

# ── AI providers ─────────────────────────────────────────────────────────────
# OpenRouter key — used by the main LLM (PydanticAI agent)
OPENROUTER_API_KEY=

# Model to use via OpenRouter (default: moonshotai/kimi-k2.6)
MODEL=moonshotai/kimi-k2.6

# OpenAI key — required by the codex CLI tool
OPENAI_API_KEY=

# Optional: route codex through OpenRouter instead of OpenAI directly
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Anthropic key — required by the claude CLI tool
ANTHROPIC_API_KEY=
